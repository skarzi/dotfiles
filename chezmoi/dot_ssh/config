# TODO(skarzi): Make it a template to add work-related hosts.
Include ~/.orbstack/ssh/config

Host *
  ConnectTimeout 30
  # NOTE: The `UseKeychain` option is specific to macOS.
  IgnoreUnknown UseKeychain

Host github.com
  User git
  Hostname ssh.github.com
  Port 443
  AddKeysToAgent yes
  UseKeychain yes
  UpdateHostKeys yes
  IdentityFile ~/.ssh/id_ed25519
