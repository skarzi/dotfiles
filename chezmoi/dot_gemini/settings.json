{
  "context": {
    "fileName": [
      "AGENTS.md",
      "GEMINI.md",
      "CLAUDE.md",
      "INSTRUCTIONS.md"
    ]
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "general": {
    "preferredEditor": "neovim",
    "vimMode": true,
    "enableNotifications": true,
    "plan": {
      "directory": ".agents/plans"
    }
  },
  "ui": {
    "footer": {
      "hideContextPercentage": false
    },
    "inlineThinkingMode": "full",
    "loadingPhrases": "tips",
    "showCitations": true,
    "showLineNumbers": true,
    "showMemoryUsage": true,
    "showModelInfoInChat": true,
    "showStatusInTitle": true
  },
  "tools": {
    "shell": {
      "showColor": true
    }
  },
  "mcpServers": {
    "MCP_DOCKER": {
      "command": "docker",
      "args": [
        "mcp",
        "gateway",
        "run"
      ]
    }
  },
  "model": {
    "name": "gemini-3.1-pro-preview"
  },
  "experimental": {
    "worktrees": true,
    "modelSteering": true
  }
}
