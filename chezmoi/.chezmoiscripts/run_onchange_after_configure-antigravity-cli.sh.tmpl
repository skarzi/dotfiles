#!/usr/bin/env bash
# shellcheck shell=bash

set -eufo pipefail

# Install plugins using `agy` CLI from GitHub URLs.
if command -v agy &>/dev/null; then
  echo "Installing plugins via agy CLI..."
  agy plugin install https://github.com/mksglu/context-mode.git
  agy plugin install \
    https://github.com/mksglu/context-mode/tree/main/configs/antigravity-cli
else
  echo "Warning: agy CLI not found. Skipping plugin installations." >&2
fi
